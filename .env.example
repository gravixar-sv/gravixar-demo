## Public origin — used for canonical URLs and OG tags
NEXT_PUBLIC_SITE_URL="https://demo.gravixar.com"

## Hard-on demo flag. Side-effect interceptors check this at boot.
## Should be true everywhere this app is deployed. If you ever set this
## to false you've made the demo into a real product, which is not what
## demo.gravixar.com is.
GRAVIXAR_DEMO_MODE="true"

## Database — Neon via Vercel Marketplace auto-injects these.
DATABASE_URL=""
DIRECT_URL=""

## NextAuth — JWT signing
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3400"

## Resend — sending emails is stubbed in demo mode, but the key still
## drives the captured-emails inspector. Set DEV_EMAIL_OVERRIDE to your
## inbox so any "send" lands there, never to fake addresses.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="hello@demo.gravixar.com"
DEV_EMAIL_OVERRIDE="gravixar@gmail.com"

## Anthropic via AI Gateway (preferred) — for the Studio Mix agent demos
AI_GATEWAY_API_KEY=""
ANTHROPIC_API_KEY=""

## Vercel Cron auth — production cron requests must include
## Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=""
