    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "botid": "^1.5.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "lucide-react": "^1.21.0",
