  "devDependencies": {
    "@gravixar-sv/core": "^0.7.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@vercel/config": "^0.5.5",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "prisma": "^7.8.0",
    "puppeteer-core": "^25.1.0",
    "tailwindcss": "^4.3.2",
