    "next-auth": "^5.0.0-beta.30",
    "next-mdx-remote": "^6.0.0",
    "pg": "^8.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zod": "^4.4.3"
