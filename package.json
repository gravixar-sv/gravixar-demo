{
  "name": "gravixar-demo",
  "version": "0.1.0",
  "private": true,
  "description": "demo.gravixar.com — multi-scene design + capability showroom for Gravixar",
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "fast-uri@<3.1.4": "^3.1.4",
      "sharp@<0.35.0": "^0.35.0",
      "next@<16.2.6": "^16.2.6",
      "@hono/node-server@<1.19.13": "^1.19.13",
      "hono@<4.12.27": "^4.12.27",
      "js-yaml@<4.3.0": "^4.3.0",
      "brace-expansion@<1.1.16": "^1.1.16",
      "brace-expansion@>=3.0.0 <5.0.7": "^5.0.7",
      "postcss@<8.5.10": "^8.5.10",
      "uuid@<11.1.1": "^11.1.1",
      "@babel/core@<7.29.6": "^7.29.6",
      "esbuild@<0.28.1": "^0.28.1",
      "undici@<6.27.0": "^6.27.0"
    }
  },
  "scripts": {
    "dev": "next dev --port 3400",
    "build": "next build",
    "start": "next start --port 3400",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "capture": "node scripts/capture.mjs",
    "verify:learn-beat": "node scripts/verify-learn-beat.mjs",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file=.env.local prisma/seed.ts",
    "db:reset": "prisma migrate reset --force --skip-seed && pnpm db:seed"
